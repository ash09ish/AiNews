# Server
PORT=5000
CLIENT_ORIGIN=http://localhost:5173
MONGODB_URI=mongodb://127.0.0.1:27017/newsvisionai

# Authentication
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# News providers
NEWSAPI_BASE_URL=https://newsapi.org/v2
NEWSAPI_KEY=
NEWS_PAGE_SIZE=20
GNEWS_API_KEY=
NEWS_REFRESH_SECONDS=30
PERSIST_NEWS=false

# Optional Hugging Face transformer pipelines
HF_ENABLE_TRANSFORMERS=false
HF_SUMMARY_MODEL=Xenova/distilbart-cnn-6-6
HF_SENTIMENT_MODEL=Xenova/distilbert-base-uncased-finetuned-sst-2-english

# Vite client
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000
